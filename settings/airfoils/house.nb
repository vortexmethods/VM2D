Cell[BoxData[
 RowBox[{
  RowBox[{"geom2", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"RotationMatrix", "[", 
       FractionBox["Pi", "5"], "]"}], ".", 
      RowBox[{"geom1", "[", 
       RowBox[{"[", "i", "]"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"Length", "[", "geom1", "]"}]}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{
  3.9722795358926125`*^9, {3.972279602379423*^9, 3.972279645022991*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"72d73658-5ce2-7345-ac5f-ba6d8e038d19"],

Cell[BoxData[
 RowBox[{
  RowBox[{"geom3", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"RotationMatrix", "[", 
       FractionBox[
        RowBox[{"-", "Pi"}], "5"], "]"}], ".", 
      RowBox[{"geom1", "[", 
       RowBox[{"[", "i", "]"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"Length", "[", "geom1", "]"}]}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
