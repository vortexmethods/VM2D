Cell[BoxData[
 RowBox[{
  RowBox[{"geom1", "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0.5", ",", "1.0", ",", "c"}], "}"}], ",", 
      RowBox[{"{", 
