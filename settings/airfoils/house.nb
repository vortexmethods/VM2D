  3.972279215444872*^9}, {3.972279828543627*^9, 3.9722798329557705`*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"8e71fcb2-c224-fa4d-b172-08b6e5fb6e03"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"arcgen", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"p1_", ",", "p2_", ",", "p3_"}], "}"}], ",", "r_", ",", "n_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"dc", "=", 
       RowBox[{
        RowBox[{"Normalize", "[", 
         RowBox[{"p1", "-", "p2"}], "]"}], "+", 
        RowBox[{"Normalize", "[", 
         RowBox[{"p3", "-", "p2"}], "]"}]}]}], ",", "cc", ",", "th", ",", 
      "ie", ",", "det"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"EuclideanDistance", "[", 
         RowBox[{"dc", ",", 
          RowBox[{"Projection", "[", 
           RowBox[{"dc", ",", 
            RowBox[{"p1", "-", "p2"}]}], "]"}]}], "]"}], "<", 
        SuperscriptBox["10", 
         RowBox[{"-", "3"}]]}], ",", 
       RowBox[{"ie", "=", "0"}], ",", 
       RowBox[{"ie", "=", 
        FractionBox["1", 
         RowBox[{"EuclideanDistance", "[", 
          RowBox[{"dc", ",", 
           RowBox[{"Projection", "[", 
            RowBox[{"dc", ",", 
             RowBox[{"p1", "-", "p2"}]}], "]"}]}], "]"}]]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"cc", "=", 
      RowBox[{"p2", "+", 
       RowBox[{"r", " ", "dc", "*", "ie"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"ie", "==", "0"}], ",", 
       RowBox[{"det", "=", "0"}], ",", 
       RowBox[{"det", "=", 
        RowBox[{"Det", "[", 
         RowBox[{"PadRight", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"p1", ",", "p2", ",", "p3"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"3", ",", "3"}], "}"}], ",", "1"}], "]"}], "]"}]}]}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"th", "=", 
      RowBox[{
       RowBox[{"Sign", "[", "det", "]"}], " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Pi]", "-", 
          RowBox[{"VectorAngle", "[", 
           RowBox[{
            RowBox[{"p3", "-", "p2"}], ",", 
            RowBox[{"p1", "-", "p2"}]}], "]"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}]}]}]}], ";", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "\:043f\:0440\:0438", " ", "\:043e\:0431\:0445\:043e\:0434\:0435", " ",
         "\:043f\:0440\:043e\:0442\:0438\:0432", " ", 
        "\:0447\:0430\:0441\:043e\:0432\:043e\:0439", " ", 
        "\:0441\:0442\:0440\:0435\:043b\:043a\:0435", " ", "sign"}], " ", "=",
        " ", "1"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"NestList", "[", 
      RowBox[{
       RowBox[{"RotationTransform", "[", 
        RowBox[{"th", ",", "cc"}], "]"}], ",", 
       RowBox[{"p2", "+", 
        RowBox[{"Projection", "[", 
         RowBox[{
          RowBox[{"cc", "-", "p2"}], ",", 
          RowBox[{"p1", "-", "p2"}]}], "]"}]}], ",", 
       RowBox[{"n", "-", "1"}]}], "]"}]}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"roundedPolygon", "[", 
    RowBox[{
     RowBox[{"Polygon", "[", 
      RowBox[{"opts_", "?", "MatrixQ"}], "]"}], ",", 
     RowBox[{"r_", "?", "NumericQ"}], ",", 
     RowBox[{"n", ":", 
      RowBox[{"(", 
       RowBox[{"_Integer", "?", "Positive"}], ")"}], ":", "12"}]}], "]"}], ":=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"pts", "=", 
       RowBox[{
        RowBox[{"Split", "[", "opts", "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "}"}], ",", 
     RowBox[{"Polygon", "[", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"arcgen", "[", 
           RowBox[{"#", ",", "r", ",", "n"}], "]"}], "&"}], "/@", 
         RowBox[{"Partition", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"TrueQ", "[", 
               RowBox[{
                RowBox[{"First", "[", "pts", "]"}], "==", 
                RowBox[{"Last", "[", "pts", "]"}]}], "]"}], ",", "Most", ",", 
              "Identity"}], "]"}], "[", "pts", "]"}], ",", "3", ",", "1", ",", 
           RowBox[{"{", 
            RowBox[{"2", ",", 
             RowBox[{"-", "2"}]}], "}"}]}], "]"}]}], ",", "1"}], "]"}], 
      "]"}]}], "]"}]}], ";"}], "\n"}], "Input",
 CellChangeTimes->{{3.9187947015372615`*^9, 3.9187947015382586`*^9}, {
  3.918795243646789*^9, 3.9187952685584154`*^9}, {3.918795828220237*^9, 
