//Physical Properties
rho = 1.0;
vInf = {1.0, 0.0};
nu = 0.0002;

//Time Discretization Properties
//timeStart = 0.0;             //by default = 0.0
timeStop = 10.00001;
dt = 0.0010;
accelVel = RampCos(0.1);            //by default = RampLin(0.0)

saveVtx = binary(100);                 //by default = 100
saveVp = binary(1);                    //by default = 0
nameLength = 5;                //by default = 5

calcCoefficients = true;

//Wake Discretization Properties
eps = 0.0002;
epscol = 0.0001;
distFar = 20.0;                 //by default = 10.0
delta = 1.e-6;                  //by default = 1.e-5
vortexPerPanel = 1;             //by default = 1
maxGamma = 0.00001;                 //by default = 0.0

//Numerical Schemes
//linearSystemSolver = linearSystemGauss;     
linearSystemSolver = linearSystemFastGmres;  
velocityComputation = velocityBarnesHut;   
panelsType = panelsRectilinear; 
boundaryConditionSatisfaction = boundaryLinearLayerAverage;

//Files and parameters
airfoil = {"swimmer1000"(nPanels=1000, basePoint = {0.0, 0.0}, scale = 1.0, angle=0, chord=1.0, mechanicalSystem=mech4) };
//fileWake = { "OblakoV1000" };              //by default={}